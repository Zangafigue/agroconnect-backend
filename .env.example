# Serveur
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.xxxxx.mongodb.net/agroconnect?retryWrites=true&w=majority

# JWT — générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERER_UNE_CLE_ALEATOIRE_DE_64_BYTES
JWT_EXPIRATION=7d

# Email Resend (gratuit sur resend.com — 3000 emails/mois)
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@agroconnect.bf
FROM_NAME=AgroConnect BF
SUPPORT_EMAIL=support@agroconnect.bf

# Compte Admin (créé automatiquement au démarrage)
ADMIN_EMAIL=admin@agroconnect.bf
ADMIN_PASSWORD=CHANGER_EN_PRODUCTION

# Paramètres plateforme
COMMISSION_RATE=0.03
PLATFORM_NAME=AgroConnect BF

# CinetPay (paiement production V2 — laisser vide en V1)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# URL frontend (pour CORS en production)
FRONTEND_URL=https://agroconnect-bf.vercel.app
